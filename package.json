{
  "name": "eip6963",
  "version": "0.1.2",
  "description": "Dependency-free EVM wallet connector using native browser APIs (EIP-6963 / EIP-1193). Vanilla core + optional React hooks.",
  "type": "module",
  "license": "MIT",
  "author": "Hernan Clich",
  "homepage": "https://github.com/hernan-clich/eip6963#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hernan-clich/eip6963.git"
  },
  "bugs": {
    "url": "https://github.com/hernan-clich/eip6963/issues"
  },
  "keywords": [
    "eip6963",
    "eip1193",
    "ethereum",
    "evm",
    "wallet",
    "wallet-connector",
    "web3",
    "react",
    "metamask",
    "injected"
  ],
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup && node scripts/postbuild.mjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "lint": "biome lint src",
    "format": "biome format --write src",
    "format:check": "biome format src",
    "check": "biome check src",
    "check:fix": "biome check --write src",
    "preversion": "npm run typecheck && npm run check && npm run build",
    "release": "npm version patch && git push --follow-tags",
    "release:minor": "npm version minor && git push --follow-tags",
    "release:major": "npm version major && git push --follow-tags"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.0"
  }
}
